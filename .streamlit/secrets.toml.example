# TEMPLATE — do NOT put real values here and do NOT commit real secrets.
# On Streamlit Community Cloud: your app → Settings (⋮) → Secrets → paste these
# two lines with YOUR values, then Save.

APP_PASSWORD = "change-this-to-a-strong-password"

# Your Supabase SESSION POOLER string (Connect -> Session pooler).
# Use the pooler one (...pooler.supabase.com), NOT the direct db.xxx.supabase.co
# one (that is IPv6-only and won't connect on Streamlit Cloud).
# Special characters in the password are handled automatically.
DB_URL = "postgresql://postgres.YOUR-REF:YOUR-DB-PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"
